      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Movie discovery will appear here when TMDB returns results."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Добірка фільмів зʼявиться тут, коли TMDB поверне результати."
